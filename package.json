{
  "name": "@vitus-labs/ui-system-root",
  "version": "0.0.0",
  "private": true,
  "description": "vitus-labs",
  "author": "Vit Bokisch <vit@bokisch.cz>",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/vitus-labs/ui-system#readme",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "release": "lerna publish --force-publish",
    "lint": "biome check packages/*/src/",
    "pkgs:clean": "rm -rf node_modules/ bun.lock && bun install",
    "pkgs:build": "lerna run build --stream",
    "test": "vitest run",
    "typecheck": "lerna run typecheck --stream",
    "format": "biome format --write .",
    "atlas": "vl_atlas"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitus-labs/ui-system.git"
  },
  "bugs": {
    "url": "https://github.com/vitus-labs/ui-system/issues"
  },
  "packageManager": "bun@1.3.9",
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-is": "^19.2.0",
    "@vitus-labs/tools-atlas": "1.9.1-alpha.1",
    "@vitus-labs/tools-lint": "1.9.1-alpha.19",
    "@vitus-labs/tools-vitest": "1.9.1-alpha.1",
    "cpr": "^3.0.1",
    "csstype": "^3.2.3",
    "jsdom": "^28.1.0",
    "lerna": "^9.0.4",
    "react": "^19.2.4",
    "react-docgen-typescript-webpack-plugin": "^1.1.0",
    "react-dom": "^19.2.4",
    "react-icons-kit": "^2.0.0",
    "ts-patch": "^3.3.0",
    "typescript": "5.9.3",
    "typescript-transform-paths": "^3.5.6",
    "vitest": "^4.0.18"
  }
}

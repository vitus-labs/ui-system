{
  "name": "@vitus-labs/ui-system-root",
  "version": "0.0.0",
  "private": true,
  "description": "vitus-labs",
  "author": "Vit Bokisch <vit@bokisch.cz>",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/vitus-labs/ui-system#readme",
  "workspaces": [
    "packages/*",
    "examples/nextjs-*",
    "examples/vite-*"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "lint": "biome check packages/*/src/",
    "pkgs:clean": "rm -rf node_modules/ bun.lock && bun install",
    "pkgs:build": "bun run --filter './packages/*' build",
    "test": "vitest run",
    "typecheck": "bun run --filter './packages/*' typecheck",
    "format": "biome format --write .",
    "atlas": "vl_atlas"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitus-labs/ui-system.git"
  },
  "bugs": {
    "url": "https://github.com/vitus-labs/ui-system/issues"
  },
  "packageManager": "bun@1.3.10",
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-is": "^19.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitus-labs/tools-atlas": "1.15.5",
    "@vitus-labs/tools-lint": "1.15.5",
    "@vitus-labs/tools-vitest": "1.15.5",
    "cpr": "^3.0.1",
    "csstype": "^3.2.3",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-docgen-typescript-webpack-plugin": "^1.1.0",
    "react-dom": "^19.2.5",
    "react-icons-kit": "^2.0.0",
    "ts-patch": "^3.3.0",
    "typescript": "6.0.3",
    "typescript-transform-paths": "^3.5.6",
    "vitest": "^4.1.5"
  },
  "resolutions": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}

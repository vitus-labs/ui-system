{
  "name": "@vitus-labs/ui-system-root",
  "version": "0.0.0",
  "private": true,
  "description": "vitus-labs",
  "author": "Vit Bokisch <vit@bokisch.cz>",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/vitus-labs/ui-system#readme",
  "workspaces": [
    "packages/*",
    "examples/nextjs-*",
    "examples/vite-*"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "rewrite-workspace-peers": "node scripts/rewrite-workspace-peers.mjs",
    "logos": "bun scripts/generate-package-logos.mjs",
    "release": "bun run rewrite-workspace-peers && changeset publish",
    "lint": "biome check packages/*/src/",
    "pkgs:clean": "rm -rf node_modules/ bun.lock && bun install",
    "pkgs:build": "bun run --filter './packages/*' build",
    "test": "vitest run",
    "typecheck": "bun run --filter './packages/*' typecheck",
    "size": "size-limit",
    "licenses": "bun scripts/check-licenses.ts",
    "format": "biome format --write .",
    "atlas": "vl_atlas"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitus-labs/ui-system.git"
  },
  "bugs": {
    "url": "https://github.com/vitus-labs/ui-system/issues"
  },
  "packageManager": "bun@1.3.14",
  "devDependencies": {
    "@biomejs/biome": "~2.4.16",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@size-limit/file": "^12.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-is": "^19.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitus-labs/tools-atlas": "2.5.0",
    "@vitus-labs/tools-lint": "2.5.0",
    "@vitus-labs/tools-typescript": "2.5.0",
    "@vitus-labs/tools-vitest": "2.5.0",
    "csstype": "^3.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "size-limit": "^12.1.0",
    "ts-patch": "^4.0.1",
    "typescript": "6.0.3",
    "typescript-transform-paths": "^4.0.0",
    "vitest": "^4.1.9"
  },
  "resolutions": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shell-quote": "^1.8.4"
  },
  "dependencies": {
    "@storybook/react": "^10.4.6",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitus-labs/tools-rolldown": "^2.5.0",
    "@vitus-labs/tools-storybook": "^2.5.0",
    "goober": "^2.1.19",
    "next": "^16.2.9",
    "react-is": "^19.2.7",
    "react-native": "^0.85.3",
    "styled-components": "^6.4.3",
    "sugar-high": "^1.2.1",
    "tinybench": "^6.0.2",
    "vite": "^8.1.0"
  }
}

{
  "extends": "@vitus-labs/tools-typescript/lib",
  "include": ["src"],
  "exclude": ["node_modules", "lib", "src/**/__stories__"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": ["@vitus-labs/tools-rolldown/global", "vitest/globals", "@testing-library/jest-dom/vitest"],
    "rootDir": "src",
    "outDir": "lib",
    "baseUrl": ".",
    "preserveSymlinks": false,
    "paths": {
      "~/*": ["src/*"]
    }
  }
}

  "license": "MIT",
  "author": "Vit Bokisch <vit@bokisch.cz>",
  "maintainers": [
    "Vit Bokisch <vit@bokisch.cz>"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "source": "./src/index.ts",
    "import": "./lib/index.js",
    "types": "./lib/index.d.ts"
  },
  "types": "./lib/index.d.ts",
  "main": "./lib/index.js",
  "files": [
    "lib",
    "!lib/**/*.map",
    "!lib/analysis"
  ],
  "homepage": "https://github.com/vitus-labs/ui-system/tree/master/packages/attrs",
  "description": "Attrs hoc chaining for React components",
  "keywords": [
    "flexible",
    "extensible",
    "powerful",
    "system",
    "react",
    "reusability",
    "extensible"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vitus-labs/ui-system",
    "directory": "packages/attrs"
  },
  "bugs": {
    "url": "https://github.com/vitus-labs/ui-system/issues"
  },
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "dev": "bun run vl_stories",
    "prepublish": "bun run build",
    "build": "bun run vl_rolldown_build",
    "build:watch": "bun run vl_rolldown_build-watch",
    "lint": "biome check src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "cover": "coveralls < .coverage/lcov.info",
    "typecheck": "tsc --noEmit",
    "version": "node ../../scripts/sync-peer-deps.mjs"
  },
  "peerDependencies": {
    "@vitus-labs/core": "2.0.0",
    "react": ">= 19"
  },
  "devDependencies": {
    "@vitus-labs/core": "workspace:*",
    "@vitus-labs/elements": "workspace:*",
    "@vitus-labs/tools-rolldown": "2.3.0",
    "@vitus-labs/tools-storybook": "2.3.0",
    "@vitus-labs/tools-typescript": "2.3.0"
  }
}

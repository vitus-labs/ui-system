{
  "name": "@vitus-labs/kinetic-presets",
  "version": "2.0.0-beta.0",
  "description": "65+ animation presets, factories, and composition utilities for @vitus-labs/kinetic",
  "license": "MIT",
  "author": "Vit Bokisch <vit@bokisch.cz>",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "source": "./src/index.ts",
    "import": "./lib/index.js",
    "types": "./lib/index.d.ts"
  },
  "types": "./lib/index.d.ts",
  "main": "./lib/index.js",
  "files": [
    "lib",
    "!lib/**/*.map",
    "!lib/analysis"
  ],
  "scripts": {
    "prepublish": "bun run build",
    "build": "bun run vl_rolldown_build",
    "build:watch": "bun run vl_rolldown_build-watch",
    "lint": "biome check src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">= 19"
  },
  "devDependencies": {
    "@vitus-labs/tools-rolldown": "1.11.0",
    "@vitus-labs/tools-typescript": "1.10.0"
  }
}

  "maintainers": [
    "Vit Bokisch <vit@bokisch.cz>"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "source": "./src/index.ts",
    "import": "./lib/index.js",
    "types": "./lib/index.d.ts"
  },
  "types": "./lib/index.d.ts",
  "main": "./lib/index.js",
  "files": [
    "lib",
    "!lib/**/*.map",
    "!lib/analysis"
  ],
  "homepage": "https://github.com/vitus-labs/ui-system/tree/master/packages/connector-native",
  "description": "React Native connector for @vitus-labs/core CSS engine",
  "keywords": [
    "vitus-labs",
    "connector",
    "react-native",
    "css-in-js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vitus-labs/ui-system",
    "directory": "packages/connector-native"
  },
  "bugs": {
    "url": "https://github.com/vitus-labs/ui-system/issues"
  },
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "prepublish": "bun run build",
    "build": "bun run vl_rolldown_build",
    "build:watch": "bun run vl_rolldown_build-watch",
    "lint": "biome check src/",
    "typecheck": "tsc --noEmit",
    "version": "node ../../scripts/sync-peer-deps.mjs"
  },
  "peerDependencies": {
    "react": ">= 19",
    "react-native": ">= 0.76"
  },
  "devDependencies": {
    "@vitus-labs/tools-rolldown": "2.0.0",
    "@vitus-labs/tools-typescript": "2.0.0"
